local antiLagButton = enchancementssubTabmS:Button({
    Title = "Anti Lag",
    Desc = "Renders down everything to decrease lag",
    Locked = false,
    Callback = function()
        local p = game:GetService("Players")
        local l = p.LocalPlayer
        local g = game:GetService("Lighting")
        local w = game:GetService("Workspace")
        local s = settings()

        local function q(c)
            for _, v in pairs(c:GetDescendants()) do
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Highlight") then
                    v.Enabled = false
                elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("SurfaceAppearance") then
                    v:Destroy()
                elseif v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
                    v.Enabled = false
                elseif v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then
                    v:Destroy()
                elseif v:IsA("Accessory") then
                    v:Destroy()
                elseif v:IsA("MeshPart") or v:IsA("UnionOperation") or v:IsA("Part") then
                    v.Material = Enum.Material.SmoothPlastic
                    v.Reflectance = 0
                    v.CastShadow = false
                end
            end
        end

        for _, plr in pairs(p:GetPlayers()) do
            if plr ~= l and plr.Character then
                q(plr.Character)
                plr.CharacterAdded:Connect(function(c)
                    q(c)
                end)
            end
        end

        p.PlayerAdded:Connect(function(plr)
            if plr ~= l then
                plr.CharacterAdded:Connect(function(c)
                    q(c)
                end)
            end
        end)

        for _, d in pairs(w:GetDescendants()) do
            if d:IsA("Decal") or d:IsA("Texture") then
                d:Destroy()
            end
        end

        s.Rendering.QualityLevel = Enum.QualityLevel.Level01
        g.GlobalShadows = false
        g.FogEnd = 9e9
        g.Brightness = 2
        g.EnvironmentDiffuseScale = 0
        g.EnvironmentSpecularScale = 0

        local t = w:FindFirstChildOfClass("Terrain")
        if t then
            t.WaterReflectance = 0
            t.WaterTransparency = 1
            t.WaterWaveSize = 0
            t.WaterWaveSpeed = 0
        end
    end
})

