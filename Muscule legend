			end

			pingGui = Instance.new("ScreenGui")
			pingGui.Name = "PingGraph"
			pingGui.ResetOnSpawn = false
			pingGui.DisplayOrder = 9999
			pingGui.IgnoreGuiInset = true
			pcall(function() pingGui.Parent = CoreGui end)
			if not pingGui.Parent then
				pingGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
			end

			local vp = workspace.CurrentCamera.ViewportSize
			local s = math.min(vp.X, vp.Y) / 400
			local fw = math.floor(180 * s)
			local fh = math.floor(70 * s)

			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(0, fw, 0, fh)
			frame.Position = UDim2.new(0, 12, 0, math.floor(52 * s))
			frame.BackgroundColor3 = Color3.fromRGB(14, 14, 18)
			frame.BackgroundTransparency = 0.1
			frame.BorderSizePixel = 0
			frame.Parent = pingGui

			local corner = Instance.new("UICorner", frame)
			corner.CornerRadius = UDim.new(0, math.floor(10 * s))

			local stroke = Instance.new("UIStroke", frame)
			stroke.Color = Color3.fromRGB(80, 80, 100)
			stroke.Thickness = 1
			stroke.Transparency = 0.4

			local headerH = math.floor(22 * s)

			local dot = Instance.new("Frame")
			dot.Size = UDim2.new(0, math.floor(7 * s), 0, math.floor(7 * s))
			dot.AnchorPoint = Vector2.new(0, 0.5)
			dot.Position = UDim2.new(0, math.floor(7 * s), 0, math.floor(headerH * 0.5))
			dot.BackgroundColor3 = Color3.fromRGB(72, 255, 120)
			dot.BorderSizePixel = 0
			dot.Parent = frame
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, -math.floor(18 * s), 0, headerH)
			label.Position = UDim2.new(0, math.floor(18 * s), 0, 0)
			label.BackgroundTransparency = 1
			label.TextColor3 = Color3.fromRGB(230, 230, 240)
			label.Font = Enum.Font.GothamBold
			label.TextScaled = true
			label.Text = "Ping: -- ms"
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local divider = Instance.new("Frame")
			divider.Size = UDim2.new(1, -math.floor(10 * s), 0, 1)
			divider.Position = UDim2.new(0, math.floor(5 * s), 0, headerH)
			divider.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
			divider.BackgroundTransparency = 0.3
			divider.BorderSizePixel = 0
			divider.Parent = frame

			local graph = Instance.new("Frame")
			graph.Size = UDim2.new(1, -math.floor(6 * s), 0, fh - headerH - math.floor(6 * s))
			graph.Position = UDim2.new(0, math.floor(3 * s), 0, headerH + math.floor(3 * s))
			graph.BackgroundTransparency = 1
			graph.ClipsDescendants = true
			graph.Parent = frame

			makeDraggable(frame)

			local points = {}
			local maxBars = 40
			local lastPing = tick()
			local interval = 0.15
			local pingTimer = 0

			local function addBar(ms)
				if #points >= maxBars then
					points[1]:Destroy()
					table.remove(points, 1)
				end
				local gw = graph.AbsoluteSize.X
				local gh = graph.AbsoluteSize.Y
				local barW = math.max(2, math.floor(gw / maxBars) - 1)
				local barH = math.clamp(math.floor(ms / 200 * gh), 2, gh)
				local col
				if ms <= 80 then
					col = Color3.fromRGB(72, 255, 120)
				elseif ms <= 140 then
					col = Color3.fromRGB(255, 200, 50)
				else
					col = Color3.fromRGB(255, 80, 80)
				end
				for idx, b in ipairs(points) do
					b.Position = UDim2.new(0, (idx - 1) * (barW + 1), 1, 0)
				end
				local bar = Instance.new("Frame")
				bar.AnchorPoint = Vector2.new(0, 1)
				bar.Size = UDim2.new(0, barW, 0, barH)
				bar.Position = UDim2.new(0, #points * (barW + 1), 1, 0)
				bar.BackgroundColor3 = col
				bar.BorderSizePixel = 0
				bar.Parent = graph
				Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 1)
				table.insert(points, bar)
				dot.BackgroundColor3 = col
			end

			RunService.Heartbeat:Connect(function(dt)
				if not pingGui or not pingGui.Enabled then return end
				pingTimer = pingTimer + dt
				if pingTimer >= interval then
					pingTimer = 0
					local ms = math.floor(Players.LocalPlayer:GetNetworkPing() * 1000 + 0.5)
					label.Text = "Ping: " .. ms .. " ms"
					addBar(ms)
				end
			end)
		else
			if pingGui then pingGui.Enabled = false end
		end
	end
})

