local function getDeviceType()
    local uis = UserInputService
    if uis.PreferredInput then
        local pi = uis.PreferredInput
        if pi == Enum.PreferredInput.Touch then return "MOBILE"
        elseif pi == Enum.PreferredInput.Gamepad then return "CONSOLE"
        else return "PC" end
    end
    if uis.TouchEnabled and not uis.KeyboardEnabled then return "MOBILE"
    elseif uis.KeyboardEnabled and uis.MouseEnabled then return "PC"
    elseif uis.GamepadEnabled then return "CONSOLE"
    else return "UNKNOWN" end
end
