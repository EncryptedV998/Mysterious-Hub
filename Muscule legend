local function clamp(v, mn, mx) return math.max(mn, math.min(mx, v)) end

local function makeDraggable(frame)
	local dragging, dragStart, startPos = false, nil, nil

	frame.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = i.Position
			startPos = frame.Position
		end
	end)

	frame.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(i)
		if not dragging then return end
		if i.UserInputType == Enum.UserInputType.MouseMovement
			or i.UserInputType == Enum.UserInputType.Touch then
			local d = i.Position - dragStart
			local vp = workspace.CurrentCamera.ViewportSize
			local fw = frame.AbsoluteSize.X
			local fh = frame.AbsoluteSize.Y
			local nx = clamp(startPos.X.Offset + d.X, 0, vp.X - fw)
			local ny = clamp(startPos.Y.Offset + d.Y, 0, vp.Y - fh)
			frame.Position = UDim2.new(0, nx, 0, ny)
		end
	end)
end

local function scaleOffset(px, py)
	local vp = workspace.CurrentCamera.ViewportSize
	local s = math.min(vp.X, vp.Y) / 400
	return px * s, py * s
end

local fpsToggle = uISeccS:Toggle({
	Title = "FPS Counter",
	Desc = "",
	Icon = "check",
	Type = "Checkbox",
	Value = false,
	Callback = function(state)
		if state then
			if fpsGui and fpsGui.Parent then
				fpsGui.Enabled = true
				return
			end

			fpsGui = Instance.new("ScreenGui")
			fpsGui.Name = "FPS_Counter"
			fpsGui.ResetOnSpawn = false
			fpsGui.DisplayOrder = 9999
			fpsGui.IgnoreGuiInset = true
			pcall(function() fpsGui.Parent = CoreGui end)
			if not fpsGui.Parent then
				fpsGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
			end

			local vp = workspace.CurrentCamera.ViewportSize
			local s = math.min(vp.X, vp.Y) / 400
			local fw, fh = math.floor(110 * s), math.floor(32 * s)

			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(0, fw, 0, fh)
			frame.Position = UDim2.new(0, 12, 0, 12)
			frame.BackgroundColor3 = Color3.fromRGB(14, 14, 18)
			frame.BackgroundTransparency = 0.1
			frame.BorderSizePixel = 0
			frame.Parent = fpsGui

			local corner = Instance.new("UICorner", frame)
			corner.CornerRadius = UDim.new(0, math.floor(8 * s))

			local stroke = Instance.new("UIStroke", frame)
			stroke.Color = Color3.fromRGB(80, 80, 100)
			stroke.Thickness = 1
			stroke.Transparency = 0.4

			local dot = Instance.new("Frame")
			dot.Size = UDim2.new(0, math.floor(8 * s), 0, math.floor(8 * s))
			dot.AnchorPoint = Vector2.new(0, 0.5)
			dot.Position = UDim2.new(0, math.floor(8 * s), 0.5, 0)
			dot.BackgroundColor3 = Color3.fromRGB(72, 255, 120)
			dot.BorderSizePixel = 0
			dot.Parent = frame
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, -math.floor(20 * s), 1, 0)
			label.Position = UDim2.new(0, math.floor(20 * s), 0, 0)
			label.BackgroundTransparency = 1
			label.TextColor3 = Color3.fromRGB(230, 230, 240)
			label.Font = Enum.Font.GothamBold
			label.TextScaled = true
			label.Text = "FPS: --"
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			makeDraggable(frame)

			local last = tick()
			local smooth = 1 / 60
			local timer = 0
			local interval = 0.12

			RunService.RenderStepped:Connect(function()
				if not fpsGui or not fpsGui.Enabled then return end
				local now = tick()
				local dt = now - last
				last = now
				smooth = smooth * 0.87 + dt * 0.13
				timer = timer + dt
				if timer >= interval then
					timer = 0
					local f = math.floor(1 / smooth + 0.5)
					label.Text = "FPS: " .. f
					if f >= 55 then
						dot.BackgroundColor3 = Color3.fromRGB(72, 255, 120)
					elseif f >= 30 then
						dot.BackgroundColor3 = Color3.fromRGB(255, 200, 80)
					else
						dot.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
					end
				end
			end)
		else
			if fpsGui then fpsGui.Enabled = false end
		end
	end
})

